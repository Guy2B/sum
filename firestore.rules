rules_version = '2';
service cloud.firestore { match /databases/{database}/documents {
  function signedIn(){ return request.auth != null; }
  function owner(uid){ return signedIn() && request.auth.uid == uid; }
  match /profiles/{uid} { allow read,create,update: if owner(uid); allow delete: if false; }
  match /{collection}/{docId} {
    allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
    allow read,update,delete: if signedIn() && resource.data.userId == request.auth.uid;
  }
  match /public_config/{id} { allow read: if true; allow write: if false; }
}}

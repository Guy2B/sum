{
  "name": "sigma-life-os-mobile",
  "private": true,
  "version": "1.7.0",
  "type": "module",
  "scripts": {
    "prepare:web": "node scripts/prepare-web.mjs",
    "sync": "npm run prepare:web && npx cap sync",

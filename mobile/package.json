    "check": "npx tsc --noEmit --skipLibCheck src/health-contract.ts capacitor.config.ts"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/core": "^7.4.3",
    "@capacitor/ios": "^7.4.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.3",
    "typescript": "^5.8.3"
  }
}
